import re

def validate_card(card):
    # 1. Check basic structure: Starts with 4,5,6. 
    # Exactly 16 digits total. 
    # Can be 16 digits straight OR four groups of 4 separated by hyphens.
    structure_regex = r"^[456]\d{3}(-?\d{4}){3}$"
    
    # 2. Check for 4 or more consecutive repeated digits.
    # We remove hyphens first to check the raw digit sequence.
    clean_card = card.replace("-", "")
    consecutive_regex = r"(\d)\1{3,}"
    
    if re.match(structure_regex, card):
        if not re.search(consecutive_regex, clean_card):
            return "Valid"
    return "Invalid"

# Example usage based on your input:
n = int(input())
for _ in range(n):
    print(validate_card(input().strip()))
